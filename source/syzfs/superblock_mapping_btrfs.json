  "disk_to_mem_mappings": [
    {
      "disk_field": "disk_super->nodesize",
      "mem_field": "fs_info->nodesize",
      "transform": "direct",
      "detail": "nodesize = btrfs_super_nodesize(disk_super). Accessor: get_unaligned_le32(&s->nodesize)"
    },
    {
      "disk_field": "disk_super->sectorsize",
      "mem_field": "fs_info->sectorsize",
      "transform": "direct",
      "detail": "fs_info->sectorsize = btrfs_super_sectorsize(disk_super). Accessor: get_unaligned_le32"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "fs_info->sectorsize_bits",
      "transform": "log2_scale",
      "detail": "fs_info->sectorsize_bits = ilog2(sectorsize)"
    },
    {
      "disk_field": "disk_super->csum_type",
      "mem_field": "fs_info->csum_size",
      "transform": "conditional",
      "detail": "csum_type = btrfs_super_csum_type(disk_super); validated; fs_info->csum_size = btrfs_super_csum_size(disk_super)"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "fs_info->csums_per_leaf",
      "transform": "computed",
      "detail": "csums_per_leaf = BTRFS_MAX_ITEM_SIZE(nodesize) / csum_size"
    },
    {
      "disk_field": "disk_super->flags",
      "mem_field": "fs_info->fs_error",
      "transform": "conditional",
      "detail": "if (btrfs_super_flags & BTRFS_SUPER_FLAG_ERROR) fs_error = -EUCLEAN"
    },
    {
      "disk_field": "disk_super->num_devices",
      "mem_field": "sb->s_bdi->ra_pages",
      "transform": "computed",
      "detail": "sb->s_bdi->ra_pages *= btrfs_super_num_devices(disk_super). Accessor: get_unaligned_le64"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sb->s_blocksize",
      "transform": "direct",
      "detail": "sb->s_blocksize = sectorsize"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sb->s_blocksize_bits",
      "transform": "log2_scale",
      "detail": "sb->s_blocksize_bits = blksize_bits(sectorsize)"
    },
    {
      "disk_field": "disk_super->fsid",
      "mem_field": "sb->s_uuid",
      "transform": "direct",
      "detail": "memcpy(&sb->s_uuid, fs_info->fs_devices->fsid, BTRFS_FSID_SIZE)"
    },
    {
      "disk_field": "disk_super (full)",
      "mem_field": "fs_info->super_copy",
      "transform": "direct",
      "detail": "memcpy(fs_info->super_copy, disk_super, sizeof(*super_copy)). Full superblock preserved in memory"
    }
  ],
