      "kernel_ntfs_h": "fssourcecode612/ntfs3/ntfs.h:192",
      "kernel_ntfs_fs_h": "fssourcecode612/ntfs3/ntfs_fs.h:210",
      "kernel_super_c": "fssourcecode612/ntfs3/super.c (ntfs_fill_super, ntfs_init_from_boot)",
      "confd_constraints": "ConfD-core/Taint_Analyzer/mkntfs_constraints.json"
    }
  },
  "superblock_field_layout": [
    {
      "offset_hex": "0x0",
      "offset_dec": 0,
      "size": 3,
      "kernel_name": "jump",
      "kernel_type": "__u8[3]",
      "doc": "JMP instruction (0xEB 0x52 0x90)"
    },
    {
      "offset_hex": "0x3",
      "offset_dec": 3,
      "size": 8,
      "kernel_name": "oem_id",
      "kernel_type": "char[8]",
      "doc": "OEM ID ('NTFS    ')"
    },
    {
      "offset_hex": "0xB",
      "offset_dec": 11,
      "size": 2,
      "kernel_name": "bytes_per_sector",
      "kernel_type": "__u8[2]",
      "doc": "Bytes per sector (raw 2-byte LE encoding)"
    },
    {
      "offset_hex": "0xD",
      "offset_dec": 13,
      "size": 1,
      "kernel_name": "sectors_per_clusters",
      "kernel_type": "__s8",
      "doc": "Sectors per cluster (signed byte encoding: >=0→value, <0→1<<(-value))"
    },
    {
      "offset_hex": "0xE",
      "offset_dec": 14,
      "size": 2,
      "kernel_name": "reserved_sectors",
      "kernel_type": "__le16",
      "doc": "Reserved sectors before first FAT"
    },
    {
      "offset_hex": "0x10",
      "offset_dec": 16,
      "size": 3,
      "kernel_name": "fats",
      "kernel_type": "__u8[3]",
      "doc": "Number of FATs (always 0)"
    },
    {
      "offset_hex": "0x13",
      "offset_dec": 19,
      "size": 2,
      "kernel_name": "root_entries",
      "kernel_type": "__le16",
      "doc": "Root directory entries (always 0 for NTFS)"
    },
    {
      "offset_hex": "0x15",
      "offset_dec": 21,
      "size": 2,
      "kernel_name": "sectors",
      "kernel_type": "__le16",
      "doc": "Total sectors (LE16, 0 if >65535)"
    },
    {
      "offset_hex": "0x17",
      "offset_dec": 23,
      "size": 1,
      "kernel_name": "media",
      "kernel_type": "__u8",
      "doc": "Media descriptor (0xF8 for HDD)"
    },
    {
      "offset_hex": "0x18",
      "offset_dec": 24,
      "size": 2,
      "kernel_name": "sectors_per_fat",
      "kernel_type": "__le16",
      "doc": "Sectors per FAT (always 0 for NTFS)"
    },
    {
      "offset_hex": "0x1A",
      "offset_dec": 26,
      "size": 2,
      "kernel_name": "sct_per_track",
      "kernel_type": "__le16",
      "doc": "Sectors per track (CHS geometry)"
    },
    {
      "offset_hex": "0x1C",
      "offset_dec": 28,
      "size": 2,
      "kernel_name": "heads",
      "kernel_type": "__le16",
      "doc": "Number of heads (CHS geometry)"
    },
    {
      "offset_hex": "0x1E",
      "offset_dec": 30,
      "size": 4,
      "kernel_name": "hidden_sectors",
      "kernel_type": "__le32",
      "doc": "Hidden sectors before partition"
    },
    {
      "offset_hex": "0x22",
      "offset_dec": 34,
      "size": 4,
      "kernel_name": "sectors_per_volume",
      "kernel_type": "__le32",
      "doc": "Total sectors (LE32 if <4G)"
    },
    {
      "offset_hex": "0x26",
      "offset_dec": 38,
      "size": 4,
      "kernel_name": "large_sectors",
      "kernel_type": "__le32",
      "doc": "Total sectors (LE32 high)"
    },
    {
      "offset_hex": "0x28",
      "offset_dec": 40,
      "size": 8,
      "kernel_name": "sectors_per_volume_fl",
      "kernel_type": "__le64",
      "doc": "Total sectors (LE64, used if LE16=0)"
    },
    {
      "offset_hex": "0x30",
      "offset_dec": 48,
      "size": 8,
      "kernel_name": "mft_clst",
      "kernel_type": "__le64",
      "doc": "MFT first cluster"
    },
    {
      "offset_hex": "0x38",
      "offset_dec": 56,
      "size": 8,
      "kernel_name": "mft2_clst",
      "kernel_type": "__le64",
      "doc": "MFT mirror first cluster"
    },
    {
      "offset_hex": "0x40",
      "offset_dec": 64,
      "size": 1,
      "kernel_name": "record_size",
      "kernel_type": "__s8",
      "doc": "MFT record size (signed byte: >=0→clusters, <0→2^abs(value))"
    },
    {
      "offset_hex": "0x44",
      "offset_dec": 68,
      "size": 4,
      "kernel_name": "index_size",
      "kernel_type": "__le32",
      "doc": "Index buffer size"
    },
    {
      "offset_hex": "0x48",
      "offset_dec": 72,
      "size": 8,
      "kernel_name": "serial_num",
      "kernel_type": "__le64",
      "doc": "Volume serial number"
    },
    {
      "offset_hex": "0x50",
      "offset_dec": 80,
      "size": 4,
      "kernel_name": "checksum",
      "kernel_type": "__u32",
      "doc": "Checksum of boot sector"
    }
  ],
  "feature_bitmask_mapping": [],
  "disk_to_mem_mappings": [
    {
      "disk_field": "boot->bytes_per_sector[0..1]",
      "mem_field": "boot_sector_size",
      "transform": "direct",
      "detail": "u32 boot_sector_size = ((u32)boot->bytes_per_sector[1]<<8) | boot->bytes_per_sector[0]"
    },
    {
      "disk_field": "boot->sectors_per_clusters",
      "mem_field": "sct_per_clst",
      "transform": "conditional",
      "detail": "if val <= 0x80 → val; else → 1U << (-(s8)val). Signed-byte: positive = direct, negative = power-of-2"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->cluster_size",
      "transform": "computed",
      "detail": "sbi->cluster_size = boot_sector_size * sct_per_clst"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->cluster_bits",
      "transform": "log2_scale",
      "detail": "sbi->cluster_bits = blksize_bits(cluster_size)"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->cluster_mask",
      "transform": "computed",
      "detail": "sbi->cluster_mask = cluster_size - 1"
    },
    {
      "disk_field": "boot->record_size",
      "mem_field": "sbi->record_size",
      "transform": "conditional",
      "detail": "if recsize >= 0: recsize << cluster_bits; else: 1 << (-recsize). Signed-byte."
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->record_bits",
      "transform": "log2_scale",
      "detail": "sbi->record_bits = blksize_bits(record_size)"
    },
    {
      "disk_field": "boot->index_size",
      "mem_field": "sbi->index_size",
      "transform": "conditional",
      "detail": "Same signed-byte logic: pos → clusters<<bits, neg → 1<<(-val)"
    },
    {
      "disk_field": "boot->mft_clst",
      "mem_field": "sbi->mft.lbo",
      "transform": "computed",
      "detail": "sbi->mft.lbo = le64_to_cpu(boot->mft_clst) << cluster_bits"
    },
    {
      "disk_field": "boot->mft2_clst",
      "mem_field": "sbi->mft.lbo2",
      "transform": "computed",
      "detail": "sbi->mft.lbo2 = le64_to_cpu(boot->mft2_clst) << cluster_bits"
    },
    {
      "disk_field": "boot->sectors_per_volume",
      "mem_field": "sbi->volume.size",
      "transform": "computed",
      "detail": "sbi->volume.size = le64_to_cpu(boot->sectors_per_volume) * boot_sector_size"
    },
    {
      "disk_field": "boot->serial_num",
      "mem_field": "sbi->volume.ser_num",
      "transform": "direct",
      "detail": "sbi->volume.ser_num = le64_to_cpu(boot->serial_num)"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->max_bytes_per_attr",
      "transform": "computed",
      "detail": "record_size - ALIGN(MFTRECORD_FIXUP_OFFSET,8) - ALIGN((record_size>>SECTOR_SHIFT)*2,8) - ALIGN(sizeof(u32),8)"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->blocks_per_cluster",
      "transform": "log2_scale",
      "detail": "sbi->blocks_per_cluster = cluster_size >> sb->s_blocksize_bits"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->maxbytes",
      "transform": "computed",
      "detail": "sbi->maxbytes = (clusters << cluster_bits) - 1"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->used.bitmap.nbits",
      "transform": "computed",
      "detail": "sbi->used.bitmap.nbits = volume.size >> cluster_bits"
    }
  ],
