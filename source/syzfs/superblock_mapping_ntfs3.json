  "usage_notes": {
    "general_mechanism": "mkntfs writes user-input parameters to an NTFS boot sector (struct NTFS_BOOT, 512 bytes). Most parameters are runtime-only flags affecting format behavior.",
    "struct_note": "The mkfs JSON declares 'struct.mkntfs_options' (mkfs in-memory config). kernel struct is 'struct NTFS_BOOT' (on-disk) and 'struct ntfs_sb_info' (in-memory).",
    "volume_label_storage": "Volume label is NOT in NTFS_BOOT. It is stored in the $Volume NTFS metadata file (MFT record 3) in an ATTR_LABEL attribute.",
    "signed_byte_encoding": "sectors_per_clusters and record_size use signed byte: value >= 0 means direct value; value < 0 means 1 << abs(value). e.g. -10 in record_size means record_size = 1024 bytes.",
    "sector_size_quirks": "bytes_per_sector is stored as 2 raw bytes in LE order, NOT a standard le16 type. byte[0] must be 0, byte[1] = sector_size / 256.",
    "runtime_heavy": "11 of 17 parameters are runtime_only — most ntfs3 mkfs flags control formatting behavior rather than on-disk data."
  }
