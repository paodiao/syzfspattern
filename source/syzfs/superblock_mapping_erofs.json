  "usage_notes": {
    "general_mechanism": "mkfs.erofs writes parameters to the on-disk erofs_super_block (128 bytes min). The kernel reads this struct at mount via erofs_read_superblock() and populates erofs_sb_info.",
    "struct_note": "The mkfs JSON declares 'struct.erofs_sb_info' (kernel in-memory struct). The on-disk struct is 'struct erofs_super_block'. Most mkfs parameters affect inode content rather than superblock fields.",
    "shared_bit": "EROFS_FEATURE_INCOMPAT_FRAGMENTS and DEDUPE share the same bit (0x20). Both are always enabled together.",
    "runtime_heavy": "18 of 34 parameters are runtime_only — erofs is a read-only filesystem with many mkfs-time formatting options that do not appear in the final superblock.",
    "compressor_bitmap": "The compressor algorithm is stored as a bitmap in available_compr_algs (le16). Each bit represents one algorithm (lz4=bit0, lz4hc=bit1).",
    "log_scale": "blkszbits is a single byte storing log2(block_size). No endian conversion needed. Standard erofs block sizes: 4096 (blkszbits=12)."
  }
