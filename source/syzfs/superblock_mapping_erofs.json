  "disk_to_mem_mappings": [
    {
      "disk_field": "dsb->blkszbits",
      "mem_field": "sbi->blkszbits",
      "transform": "direct",
      "detail": "sbi->blkszbits = dsb->blkszbits (validated 9..PAGE_SHIFT)"
    },
    {
      "disk_field": "dsb->feature_compat",
      "mem_field": "sbi->feature_compat",
      "transform": "direct",
      "detail": "sbi->feature_compat = le32_to_cpu(dsb->feature_compat)"
    },
    {
      "disk_field": "dsb->feature_incompat",
      "mem_field": "sbi->feature_incompat",
      "transform": "direct",
      "detail": "sbi->feature_incompat = le32_to_cpu(dsb->feature_incompat) & EROFS_ALL_FEATURE_INCOMPAT"
    },
    {
      "disk_field": "dsb->sb_extslots",
      "mem_field": "sbi->sb_size",
      "transform": "computed",
      "detail": "sbi->sb_size = 128 + dsb->sb_extslots * EROFS_SB_EXTSLOT_SIZE"
    },
    {
      "disk_field": "dsb->blocks",
      "mem_field": "sbi->dif0.blocks",
      "transform": "direct",
      "detail": "sbi->dif0.blocks = le32_to_cpu(dsb->blocks)"
    },
    {
      "disk_field": "dsb->meta_blkaddr",
      "mem_field": "sbi->meta_blkaddr",
      "transform": "direct",
      "detail": "sbi->meta_blkaddr = le32_to_cpu(dsb->meta_blkaddr)"
    },
    {
      "disk_field": "dsb->xattr_blkaddr",
      "mem_field": "sbi->xattr_blkaddr",
      "transform": "direct",
      "detail": "sbi->xattr_blkaddr = le32_to_cpu(dsb->xattr_blkaddr); CONFIG_EROFS_FS_XATTR"
    },
    {
      "disk_field": "dsb->xattr_prefix_start",
      "mem_field": "sbi->xattr_prefix_start",
      "transform": "direct",
      "detail": "sbi->xattr_prefix_start = le32_to_cpu(dsb->xattr_prefix_start); CONFIG_EROFS_FS_XATTR"
    },
    {
      "disk_field": "dsb->xattr_prefix_count",
      "mem_field": "sbi->xattr_prefix_count",
      "transform": "direct",
      "detail": "sbi->xattr_prefix_count = dsb->xattr_prefix_count (u8); CONFIG_EROFS_FS_XATTR"
    },
    {
      "disk_field": "dsb->xattr_filter_reserved",
      "mem_field": "sbi->xattr_filter_reserved",
      "transform": "direct",
      "detail": "sbi->xattr_filter_reserved = dsb->xattr_filter_reserved (u8)"
    },
    {
      "disk_field": "dsb->root_nid",
      "mem_field": "sbi->root_nid",
      "transform": "direct",
      "detail": "sbi->root_nid = le16_to_cpu(dsb->root_nid)"
    },
    {
      "disk_field": "dsb->packed_nid",
      "mem_field": "sbi->packed_nid",
      "transform": "direct",
      "detail": "sbi->packed_nid = le64_to_cpu(dsb->packed_nid)"
    },
    {
      "disk_field": "dsb->inos",
      "mem_field": "sbi->inos",
      "transform": "direct",
      "detail": "sbi->inos = le64_to_cpu(dsb->inos)"
    },
    {
      "disk_field": "dsb->build_time",
      "mem_field": "sbi->build_time",
      "transform": "direct",
      "detail": "sbi->build_time = le64_to_cpu(dsb->build_time)"
    },
    {
      "disk_field": "dsb->build_time_nsec",
      "mem_field": "sbi->build_time_nsec",
      "transform": "direct",
      "detail": "sbi->build_time_nsec = le32_to_cpu(dsb->build_time_nsec)"
    },
    {
      "disk_field": "dsb->uuid",
      "mem_field": "sb->s_uuid",
      "transform": "direct",
      "detail": "super_set_uuid(sb, (void *)dsb->uuid, sizeof(dsb->uuid))"
    },
    {
      "disk_field": "dsb->volume_name",
      "mem_field": "sbi->volume_name",
      "transform": "direct",
      "detail": "strscpy(sbi->volume_name, dsb->volume_name, sizeof(dsb->volume_name))"
    }
  ],
