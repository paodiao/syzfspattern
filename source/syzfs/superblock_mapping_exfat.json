  "usage_notes": {
    "general_mechanism": "exfat mkfs writes user-input parameters to a boot_sector (superblock equivalent). Most parameters are runtime-only and do not appear in the on-disk structure.",
    "struct_note": "The mkfs JSON declares 'struct.exfat_user_input' (mkfs in-memory config), not the on-disk 'struct boot_sector'. kernel in-memory struct is 'struct exfat_sb_info'.",
    "volume_label_storage": "Volume label is NOT in the boot_sector. It is stored in the root directory as exFAT dentry entries, which is why it is marked runtime_only in this mapping.",
    "log_scale_fields": "sect_size_bits and sect_per_clus_bits are stored as log2 of the actual values. Example: sector_size=512 → sect_size_bits=9; cluster_size/sector_size=256 → sect_per_clus_bits=8",
    "runtime_heavy": "8 of 10 parameters are runtime_only — exfat mkfs has few tunable on-disk parameters compared to other filesystems."
  }
