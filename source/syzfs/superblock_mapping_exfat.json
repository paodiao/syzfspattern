  "feature_bitmask_mapping": [],
  "disk_to_mem_mappings": [
    {
      "disk_field": "p_boot->sect_size_bits",
      "mem_field": "sbi->sect_size_bits",
      "transform": "direct",
      "detail": "sbi->sect_size_bits = p_boot->sect_size_bits (validated 9..12)"
    },
    {
      "disk_field": "p_boot->sect_per_clus_bits",
      "mem_field": "sbi->sect_per_clus_bits",
      "transform": "direct",
      "detail": "sbi->sect_per_clus_bits = p_boot->sect_per_clus_bits"
    },
    {
      "disk_field": "p_boot->sect_per_clus_bits",
      "mem_field": "sbi->sect_per_clus",
      "transform": "log2_scale",
      "detail": "sbi->sect_per_clus = 1 << p_boot->sect_per_clus_bits"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->cluster_size_bits",
      "transform": "computed",
      "detail": "sbi->cluster_size_bits = p_boot->sect_per_clus_bits + p_boot->sect_size_bits"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->cluster_size",
      "transform": "log2_scale",
      "detail": "sbi->cluster_size = 1 << sbi->cluster_size_bits"
    },
    {
      "disk_field": "p_boot->fat_length",
      "mem_field": "sbi->num_FAT_sectors",
      "transform": "direct",
      "detail": "sbi->num_FAT_sectors = le32_to_cpu(p_boot->fat_length)"
    },
    {
      "disk_field": "p_boot->fat_offset",
      "mem_field": "sbi->FAT1_start_sector",
      "transform": "direct",
      "detail": "sbi->FAT1_start_sector = le32_to_cpu(p_boot->fat_offset)"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->FAT2_start_sector",
      "transform": "conditional",
      "detail": "FAT2 = FAT1; if num_fats==2: FAT2 += num_FAT_sectors"
    },
    {
      "disk_field": "p_boot->clu_offset",
      "mem_field": "sbi->data_start_sector",
      "transform": "direct",
      "detail": "sbi->data_start_sector = le32_to_cpu(p_boot->clu_offset)"
    },
    {
      "disk_field": "p_boot->vol_length",
      "mem_field": "sbi->num_sectors",
      "transform": "direct",
      "detail": "sbi->num_sectors = le64_to_cpu(p_boot->vol_length)"
    },
    {
      "disk_field": "p_boot->clu_count",
      "mem_field": "sbi->num_clusters",
      "transform": "conditional",
      "detail": "sbi->num_clusters = le32_to_cpu(p_boot->clu_count) + EXFAT_RESERVED_CLUSTERS (2)"
    },
    {
      "disk_field": "p_boot->root_cluster",
      "mem_field": "sbi->root_dir",
      "transform": "direct",
      "detail": "sbi->root_dir = le32_to_cpu(p_boot->root_cluster)"
    },
    {
      "disk_field": "p_boot->vol_flags",
      "mem_field": "sbi->vol_flags",
      "transform": "direct",
      "detail": "sbi->vol_flags = le16_to_cpu(p_boot->vol_flags)"
    },
    {
      "disk_field": "(derived)",
      "mem_field": "sbi->dentries_per_clu",
      "transform": "log2_scale",
      "detail": "sbi->dentries_per_clu = 1 << (cluster_size_bits - DENTRY_SIZE_BITS)"
    },
    {
      "disk_field": "p_boot->sect_size_bits",
      "mem_field": "sb->s_blocksize",
      "transform": "log2_scale",
      "detail": "exfat_calibrate_blocksize(sb, 1 << p_boot->sect_size_bits)"
    }
  ],
