  "usage_notes": {
    "general_mechanism": "mkfs.f2fs writes parameters from the f2fs_configuration struct (global @c) to the on-disk f2fs_super_block. The kernel reads via f2fs_fill_super → init_sb_info().",
    "struct_note": "The mkfs JSON declares 'struct.f2fs_configuration' (in-memory config), NOT the on-disk 'struct f2fs_super_block'. All confd_variable values use LLVM GEP path notation '@c, i32 0, i32 NN'.",
    "log2_fields": "Most size fields are stored as log2 in le32 format: log_sectorsize, log_blocksize, log_blocks_per_seg, log_sectors_per_block. The kernel uses BIT(val) = 1 << val to convert back.",
    "large_nat_bitmap_in_checkpoint": "large_nat_bitmap (-i flag) sets CP_LARGE_NAT_BITMAP_FLAG in the checkpoint, not in f2fs_super_block. It is marked runtime_only in this mapping.",
    "feature_single_bitmap": "All f2fs features are stored in a single 'feature' field (le32) via bitwise OR. The -O flag aggregates multiple features via parse_feature().",
    "init_config_blind_spot": "f2fs_init_configuration() defaults are in libf2fs.c (shared library, not in the 3 mkfs .ll files). Some parameters may have their initial values set by this external function and are invisible to ConD's static analysis.",
    "checkpoint_fields": "fixed_time affects checkpoint timestamps, not superblock. Several mkfs parameters affect checkpoint data rather than the superblock itself."
  }
}