    },
    {
      "disk_field": "raw_super->segs_per_sec",
      "mem_field": "sbi->segs_per_sec",
      "transform": "direct",
      "detail": "sbi->segs_per_sec = le32_to_cpu(raw_super->segs_per_sec)"
    },
    {
      "disk_field": "raw_super->secs_per_zone",
      "mem_field": "sbi->secs_per_zone",
      "transform": "direct",
      "detail": "sbi->secs_per_zone = le32_to_cpu(raw_super->secs_per_zone)"
    },
    {
      "disk_field": "raw_super->section_count",
      "mem_field": "sbi->total_sections",
      "transform": "direct",
      "detail": "sbi->total_sections = le32_to_cpu(raw_super->section_count)"
    },
    {
      "disk_field": "raw_super->root_ino",
      "mem_field": "F2FS_ROOT_INO(sbi)",
      "transform": "direct",
      "detail": "F2FS_ROOT_INO(sbi) = le32_to_cpu(raw_super->root_ino); validated == 3"
    },
    {
      "disk_field": "raw_super->node_ino",
      "mem_field": "F2FS_NODE_INO(sbi)",
      "transform": "direct",
      "detail": "F2FS_NODE_INO(sbi) = le32_to_cpu(raw_super->node_ino); validated == 1"
    },
    {
      "disk_field": "raw_super->meta_ino",
      "mem_field": "F2FS_META_INO(sbi)",
      "transform": "direct",
      "detail": "F2FS_META_INO(sbi) = le32_to_cpu(raw_super->meta_ino); validated == 2"
    },
    {
      "disk_field": "raw_super->uuid",
      "mem_field": "sb->s_uuid",
      "transform": "direct",
      "detail": "super_set_uuid(sb, (void *)raw_super->uuid, sizeof(raw_super->uuid))"
    },
    {
      "disk_field": "raw_super->uuid",
      "mem_field": "sbi->s_chksum_seed",
      "transform": "conditional",
      "detail": "if (f2fs_sb_has_inode_chksum(sbi)) sbi->s_chksum_seed = f2fs_chksum(sbi, ~0, raw_super->uuid, 16)"
    },
    {
      "disk_field": "raw_super->s_errors",
